# Hover Button
def hover(btn, c1, c2):
    btn.configure(bg=c1, relief="flat", font=("Segoe UI", 10, "bold"))
    btn.bind("<Enter>", lambda e: btn.config(bg=c2))
    btn.bind("<Leave>", lambda e: btn.config(bg=c1))

