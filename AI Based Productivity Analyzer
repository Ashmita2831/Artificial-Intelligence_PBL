import tkinter as tk
from tkinter import ttk, messagebox
import matplotlib.pyplot as plt

tasks = []

# ---------------- AI LOGIC ----------------
def calculate_priority(task):
    name, priority, time = task
    score = {"High": 3, "Medium": 2, "Low": 1}[priority]
    score += time / 2
    return score

# ---------------- FUNCTIONS ----------------
def add_task():
    name = task_entry.get()
    priority = priority_box.get()
    time = time_entry.get()

    if not name or not time:
        messagebox.showwarning("Input Error", "Fill all fields")
        return

    try:
        time = int(time)
    except:
        messagebox.showerror("Error", "Time must be a number")
        return

    tasks.append((name, priority, time))

    colors = {"High": "#ffadad", "Medium": "#ffd6a5", "Low": "#caffbf"}
    listbox.insert(tk.END, f"{name} | {priority} | {time} hrs")
    listbox.itemconfig(tk.END, {'bg': colors[priority]})

    status_var.set(f"Task '{name}' added")

    task_entry.delete(0, tk.END)
    time_entry.delete(0, tk.END)

def delete_task():
    selected = listbox.curselection()
    if not selected:
        return

    index = selected[0]
    listbox.delete(index)
    tasks.pop(index)

    status_var.set("Task deleted")

def clear_tasks():
    listbox.delete(0, tk.END)
    tasks.clear()
    output.delete(1.0, tk.END)

    status_var.set("All tasks cleared")

def show_sorted():
    if not tasks:
        messagebox.showinfo("Info", "No tasks available")
        return

    sorted_tasks = sorted(tasks, key=calculate_priority, reverse=True)

    output.delete(1.0, tk.END)
    output.insert(tk.END, "Optimized Task Order:\n\n")

    for i, (name, priority, time) in enumerate(sorted_tasks, 1):
        output.insert(tk.END, f"{i}. {name} | {priority} | {time} hrs\n")

    status_var.set("Tasks optimized successfully")

def show_charts():
    if not tasks:
        messagebox.showinfo("Info", "No data available")
        return

    priorities = {"High": 0, "Medium": 0, "Low": 0}
    names, times = [], []

    for t in tasks:
        priorities[t[1]] += 1
        names.append(t[0])
        times.append(t[2])

    plt.close('all')  # Fix for charts

    # Pie Chart
    plt.figure()
    plt.pie(priorities.values(), labels=priorities.keys(), autopct='%1.1f%%')
    plt.title("Task Priority Distribution")

    # Bar Chart
    plt.figure()
    plt.bar(names, times)
    plt.title("Time Spent on Tasks")
    plt.xlabel("Tasks")
    plt.ylabel("Hours")

    plt.show()

